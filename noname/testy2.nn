Sigma0 : public yes /0 no /0 a /0 b /0 i /0 s /0

Transaction Responder :
* xB in {a , b }.
receive M .
try DEC := dcrypt ( inv ( pk ( xB ) ) ,M ) in
    try A := proj1 ( DEC ) in
        if A = i then
            new NB , R .
            send crypt ( pk ( A ) ,NB , R ) .
            * xB = gamma ( xB ) . nil
        else
            new NB , R .
            send crypt ( pk ( A ) ,NB , R ) . nil
    catch new NB . send NB . nil
catch new NB . send NB . nil

Bound : 2